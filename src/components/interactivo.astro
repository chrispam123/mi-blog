</style>

<div class="w" id="main">
  <h2 class="sr-only">
    Flujo interactivo completo del usuario en Nocturne: autenticación,
    exportación e importación
  </h2>

  <div class="phase-tabs" id="phaseTabs"></div>
  <div class="progress-bar-wrap">
    <div class="progress-label">
      <span id="progressLabel"></span><span id="progressFrac"></span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progressFill"></div>
    </div>
  </div>
  <div class="phase-title" id="phaseTitle"></div>
  <div class="phase-sub" id="phaseSub"></div>
  <div class="steps-wrap" id="stepsWrap">
    <div class="step-connector"></div>
  </div>
  <div class="nav-row">
    <button class="nav-btn" id="btnPrev" onclick="navigate(-1)"
      ><i class="ti ti-arrow-left" aria-hidden="true"></i> Anterior</button
    >
    <span class="step-counter" id="stepCounter"></span>
    <button class="nav-btn primary" id="btnNext" onclick="navigate(1)"
      >Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i></button
    >
  </div>
</div>

