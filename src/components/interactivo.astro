  .nav-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 16px;
  }
  .nav-btn {
    padding: 7px 16px;
    border-radius: var(--border-radius-md);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid var(--color-border-secondary);
    background: var(--color-background-secondary);
    color: var(--color-text-primary);
    transition: all 0.2s;
  }
  .nav-btn:hover {
    background: var(--color-background-primary);
  }
  .nav-btn:disabled {
    opacity: 0.35;
    cursor: default;
  }
  .nav-btn.primary {
    background: #534ab7;
    color: #fff;
    border-color: #534ab7;
  }
  .nav-btn.primary:hover {
    background: #3c3489;
  }
  .p1 .nav-btn.primary {
    background: #0f6e56;
    border-color: #0f6e56;
  }
  .p1 .nav-btn.primary:hover {
    background: #085041;
  }
  .p2 .nav-btn.primary {
    background: #993c1d;
    border-color: #993c1d;
  }
  .p2 .nav-btn.primary:hover {
    background: #712b13;
  }
  .step-counter {
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .progress-bar-wrap {
    margin-bottom: 16px;
  }
  .progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--color-text-secondary);
    margin-bottom: 5px;
  }
  .progress-track {
    height: 4px;
    border-radius: 2px;
    background: var(--color-border-tertiary);
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.4s ease;
  }
  .p-fill-0 {
    background: #534ab7;
  }
  .p-fill-1 {
    background: #0f6e56;
  }
  .p-fill-2 {
    background: #993c1d;
