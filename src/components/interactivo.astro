  let currentPhase = 0
  let currentStep = 0
  let openStep = 0

  function renderPhase() {
    const ph = phases[currentPhase]
    const tabs = document.getElementById('phaseTabs')
    tabs.innerHTML = ''
    phases.forEach((p, i) => {
      const b = document.createElement('button')
      b.className = 'ptab p' + i + (i === currentPhase ? ' active' : '')
      b.textContent = p.label
      b.onclick = () => {
        currentPhase = i
        currentStep = 0
        openStep = 0
        renderPhase()
      }
      tabs.appendChild(b)
    })

    document.getElementById('phaseTitle').textContent = ph.title
    document.getElementById('phaseSub').textContent = ph.sub

    const fill = Math.round(((currentStep + 1) / ph.steps.length) * 100)
    document.getElementById('progressLabel').textContent = ph.label
    document.getElementById('progressFrac').textContent =
      currentStep + 1 + '/' + ph.steps.length
    const pf = document.getElementById('progressFill')
    pf.style.width = fill + '%'
    pf.className = 'progress-fill p-fill-' + currentPhase

    document.getElementById('stepCounter').textContent =
      'Paso ' + (currentStep + 1) + ' de ' + ph.steps.length

    const wrap = document.getElementById('stepsWrap')
    const conn = wrap.querySelector('.step-connector')
    wrap.innerHTML = ''
    wrap.appendChild(conn)

    const main = document.getElementById('main')
    main.className = 'w p' + currentPhase

    ph.steps.forEach((s, i) => {
      const isDone = i < currentStep
      const isActive = i === currentStep
      const isOpen = i === openStep

      const step = document.createElement('div')
      step.className = 'step'

      const dotWrap = document.createElement('div')
      dotWrap.className = 'step-dot-wrap'
      const dot = document.createElement('div')
      dot.className =
        'step-dot' + (isDone ? ' done-dot' : isActive ? ' active-dot' : '')
      if (isDone)
        dot.innerHTML = '<i class="ti ti-check" aria-hidden="true"></i>'
      else dot.textContent = i + 1
      dotWrap.appendChild(dot)
      if (i < ph.steps.length - 1) {
        const ln = document.createElement('div')
        ln.className = 'step-line'
        dotWrap.appendChild(ln)
      }
      step.appendChild(dotWrap)

      const card = document.createElement('div')
      card.className = 'step-card' + (isActive ? ' active-card' : '')

      const hdr = document.createElement('div')
      hdr.className = 'step-header'
      const left = document.createElement('div')
      left.className = 'step-header-left'
      const badge = document.createElement('span')
      badge.className = 'step-num-badge p' + currentPhase + '-badge'
      badge.textContent = 'paso ' + (i + 1)
      const title = document.createElement('span')
      title.className = 'step-title'
      title.textContent = s.title
      left.appendChild(badge)
      left.appendChild(title)
      const chev = document.createElement('span')
      chev.className = 'step-chevron' + (isOpen ? ' open' : '')
      chev.innerHTML = '<i class="ti ti-chevron-down" aria-hidden="true"></i>'
      hdr.appendChild(left)
      hdr.appendChild(chev)
      hdr.onclick = () => {
        openStep = openStep === i ? -1 : i
        renderPhase()
      }

      const body = document.createElement('div')
      body.className = 'step-body' + (isOpen ? ' open' : '')

      const actors = document.createElement('div')
      actors.className = 'actors-row'
      s.actors.forEach((a) => {
        const [ico, lbl] = a.split(' · ')
        const el = document.createElement('span')
        el.className = 'actor'
        el.innerHTML = `<i class="ti ${ico}" aria-hidden="true"></i>${lbl}`
        actors.appendChild(el)
      })

      const desc = document.createElement('div')
      desc.className = 'step-desc'
      desc.textContent = s.desc

      const diagram = document.createElement('div')
      diagram.className = 'flow-diagram'
      s.flows.forEach((row) => {
        const fr = document.createElement('div')
        fr.className = 'flow-row'

        for (let j = 0; j < row.length; j += 4) {
          // 1. Renderizar Nodo Origen
          if (row[j] && row[j + 1]) {
            const n = document.createElement('span')
            n.className = 'fnode ' + row[j]
            n.textContent = row[j + 1]
            fr.appendChild(n)
          }

          // 2. Renderizar Flecha con su texto intermedio descriptivo
          if (row[j + 2]) {
            const arr = document.createElement('span')
            arr.className = 'farr'
            arr.innerHTML =
              '<i class="ti ti-arrow-right" aria-hidden="true"></i>'
            fr.appendChild(arr)

            if (row[j + 3]) {
              const lbl = document.createElement('span')
              lbl.style.cssText =
                'font-size: 11px; color: var(--color-text-tertiary); white-space: nowrap;'
              lbl.textContent = row[j + 3]
              fr.appendChild(lbl)
            }
          }
        }
        diagram.appendChild(fr)
      })

      if (s.state) {
        const sp = document.createElement('span')
        const stMap = {
          pending: ['st-pending', 'PENDING'],
          running: ['st-running', 'RUNNING'],
          done: ['st-done', 'DONE'],
          paused: ['st-paused', 'PAUSED'],
        }
        const [cls, lbl] = stMap[s.state]
        sp.className = 'state-pill ' + cls
        sp.innerHTML = `<i class="ti ti-database" style="font-size:12px" aria-hidden="true"></i> Job state: ${lbl}`
        body.appendChild(actors)
        body.appendChild(desc)
        body.appendChild(diagram)
        body.appendChild(sp)
      } else {
        body.appendChild(actors)
        body.appendChild(desc)
        body.appendChild(diagram)
      }

      card.appendChild(hdr)
      card.appendChild(body)
      step.appendChild(card)
      wrap.appendChild(step)
    })

    document.getElementById('btnPrev').disabled =
      currentStep === 0 && currentPhase === 0
    const isLast = currentStep === ph.steps.length - 1
    const isLastPhase = currentPhase === phases.length - 1
    const btn = document.getElementById('btnNext')
    if (isLast && isLastPhase) {
      btn.textContent = 'Flujo completo ✓'
      btn.disabled = true
    } else if (isLast) {
      btn.innerHTML =
        'Siguiente acto <i class="ti ti-arrow-right" aria-hidden="true"></i>'
    } else {
      btn.innerHTML =
        'Siguiente <i class="ti ti-arrow-right" aria-hidden="true"></i>'
    }
    btn.disabled = isLast && isLastPhase
  }

  function navigate(dir) {
    const ph = phases[currentPhase]
    if (dir === 1) {
      if (currentStep < ph.steps.length - 1) {
        currentStep++
        openStep = currentStep
      } else if (currentPhase < phases.length - 1) {
        currentPhase++
        currentStep = 0
        openStep = 0
      }
    } else {
      if (currentStep > 0) {
        currentStep--
        openStep = currentStep
      } else if (currentPhase > 0) {
        currentPhase--
        currentStep = phases[currentPhase].steps.length - 1
        openStep = currentStep
      }
    }
    renderPhase()
  }

  renderPhase()
</script>
