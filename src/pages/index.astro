---
// index.astro
// Ahora los posts se leen automáticamente desde src/content/posts/
// getCollection() es la función de Astro que lee todos los archivos
// Markdown de una colección y devuelve un array con sus datos.
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'

// Obtenemos todos los posts y los ordenamos por fecha descendente
// para que el más reciente aparezca siempre primero.
const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
---

<BaseLayout title="Inicio">
  <ul class="post-list">
    {
      posts.map((post) => (
        <li class="post-item">
          <time class="post-date">
            {post.data.date.toLocaleDateString('es-ES', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <a href={`/posts/${post.id}`} class="post-title">
            {post.data.title}
          </a>
          {post.data.description && (
            <p class="post-description">{post.data.description}</p>
          )}
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .post-item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .post-date {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 300;
    line-height: 1.2;
    text-decoration: none;
    color: var(--color-text);
  }

  .post-title:hover {
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .post-description {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
</style>
